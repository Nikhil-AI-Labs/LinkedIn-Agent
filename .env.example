# LinkedIn AI Agent - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# AUTHENTICATION MODE
# ============================================================================
# Production default: "oauth" (recommended)
# Experimental fallback: "browser" (unofficial, may break)
AUTH_MODE=browser

# ============================================================================
# DATABASE
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/linkedin_agent
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/linkedin_agent
# ============================================================================
# LLM APIs
# ============================================================================
# Sarvam AI (Primary reasoning LLM + Voice)
SARVAM_API_KEY=

# Groq (Fast classification LLM)
GROQ_API_KEY=

# ============================================================================
# SECURITY
# ============================================================================
# 32-byte base64-encoded encryption key for token storage
# Generate with: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here

ENCRYPTION_KEY=/8x6mMQjvZmoyntfCYJP4lFGrBisIhyLf8Qm0SQ8Pyo=
JWT_SECRET=GOrN3igZaW994-Ve03JFmfWsRQhK4AddzzLb0ZlArKiMXJI0tQmddjpzfPcSmty1


# ENCRYPTION_KEY=Q9n0A5dQlfmVDG07oOxomNJilb3KDu/cmQrHPF4lEGM=
# JWT_SECRET=Dsvw1aVN2DWlOFXOuWArQWTYup8jq3Gu4Ew7NpLMq-ANITJtVkhwl9gqo1TY0nLH

# JWT secret for session tokens
# JWT_SECRET=your_jwt_secret_key_here

# ============================================================================
# LINKEDIN OAUTH APP CREDENTIALS (For Official API - If Approved)
# ============================================================================
# Required for AUTH_MODE=oauth
# Get these from LinkedIn Developer Portal after app approval
# Requires "Sign In with LinkedIn using OpenID Connect" and "Share on LinkedIn" products
# Posting requires w_member_social scope (not available to most personal projects)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/linkedin/callback

# ============================================================================
# BROWSER PROVIDER CONFIGURATION (Primary Method)
# ============================================================================
# Browser provider: kimi_webbridge (recommended) or playwright (fallback)
BROWSER_PROVIDER=kimi_webbridge

# Kimi WebBridge uses your existing browser session - no credentials needed
# Only set these if using Playwright fallback or emergency login
LINKEDIN_USERNAME=nikhilpathakgonda123@gmail.com
LINKEDIN_PASSWORD=

# ============================================================================
# OBSERVABILITY
# ============================================================================
# LangSmith tracing (optional but recommended)
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=linkedin-ai-agent
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# APPLICATION CONFIG
# ============================================================================
# Logging level
LOG_LEVEL=INFO

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend URL
FRONTEND_URL=http://localhost:3000
